{
  "entities": {
    "users": {
      "title": "User",
      "description": "User profile and subscription information.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "plan": { "type": "string", "enum": ["FREE", "PRO"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "plan", "createdAt"]
    },
    "products": {
      "title": "Product",
      "description": "Pre-configured product data for quick calculations.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "supplierName": { "type": "string" },
        "regimeCompra": { "type": "string", "enum": ["Simples", "Presumido", "Real"] },
        "baseCost": { "type": "number" },
        "ipi": { "type": "number" },
        "icmsPurchaseRate": { "type": "number" },
        "icmsFreightRate": { "type": "number" },
        "pisPurchaseRate": { "type": "number" },
        "cofinsPurchaseRate": { "type": "number" },
        "regimeVenda": { "type": "string", "enum": ["Simples", "Presumido", "Real"] },
        "simplesNacionalRate": { "type": "number" },
        "icmsSaleRate": { "type": "number" },
        "pisSaleRate": { "type": "number" },
        "cofinsSaleRate": { "type": "number" },
        "irpjRate": { "type": "number" },
        "csllRate": { "type": "number" },
        "category": { "type": "string" },
        "defaultMargin": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "baseCost", "createdAt"]
    },
    "calculations": {
      "title": "Calculation",
      "description": "A saved pricing simulation.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "representativeName": { "type": "string" },
        "regimeCompra": { "type": "string", "enum": ["Simples", "Presumido", "Real"] },
        "purchasePrice": { "type": "number" },
        "freight": { "type": "number" },
        "ipi": { "type": "number" },
        "otherExpenses": { "type": "number" },
        "icmsPurchaseRate": { "type": "number" },
        "icmsFreightRate": { "type": "number" },
        "pisPurchaseRate": { "type": "number" },
        "cofinsPurchaseRate": { "type": "number" },
        "regimeVenda": { "type": "string", "enum": ["Simples", "Presumido", "Real"] },
        "simplesNacionalRate": { "type": "number" },
        "icmsSaleRate": { "type": "number" },
        "pisSaleRate": { "type": "number" },
        "cofinsSaleRate": { "type": "number" },
        "irpjRate": { "type": "number" },
        "csllRate": { "type": "number" },
        "saleExpensesValue": { "type": "number" },
        "commissionRate": { "type": "number" },
        "profitMargin": { "type": "number" },
        "salesPrice": { "type": "number" },
        "realCost": { "type": "number" },
        "totalCost": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productName", "purchasePrice", "salesPrice", "createdAt"]
    },
    "settings": {
      "title": "User Settings",
      "description": "Global default tax rates and preferences.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "defaultRegimeVenda": { "type": "string", "enum": ["Simples", "Presumido", "Real"] },
        "defaultSimplesNacionalRate": { "type": "number" },
        "defaultIcmsPurchaseRate": { "type": "number" },
        "defaultIcmsFreightRate": { "type": "number" },
        "defaultPisPurchaseRate": { "type": "number" },
        "defaultCofinsPurchaseRate": { "type": "number" },
        "defaultIcmsSaleRate": { "type": "number" },
        "defaultPisSaleRate": { "type": "number" },
        "defaultCofinsSaleRate": { "type": "number" },
        "defaultIrpjRate": { "type": "number" },
        "defaultCsllRate": { "type": "number" },
        "defaultCommissionRate": { "type": "number" },
        "defaultProfitMargin": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId"]
    },
    "legal": {
      "title": "Legal Content",
      "description": "Legal texts like Privacy Policy and Terms of Use.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "Stores user profiles."
    },
    "/products/{productId}": {
      "schema": "products",
      "description": "Stores product catalog."
    },
    "/calculations/{calculationId}": {
      "schema": "calculations",
      "description": "Stores saved simulations."
    },
    "/settings/{userId}": {
      "schema": "settings",
      "description": "Stores user global settings."
    },
    "/legal/{contentId}": {
      "schema": "legal",
      "description": "Stores legal contents (privacy, terms)."
    }
  }
}
